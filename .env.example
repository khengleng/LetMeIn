# =========================
# Shared
# =========================
NODE_ENV=development
APP_URL=http://localhost:3000

# =========================
# Supabase Project
# =========================
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# JWT claim used by RLS helper function current_tenant_id()
# Include tenant_id in authenticated user JWT claims.
SUPABASE_JWT_TENANT_CLAIM=tenant_id

# =========================
# Telegram Bot
# =========================
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=YOUR_TELEGRAM_BOT_USERNAME
TELEGRAM_WEBHOOK_SECRET=YOUR_TELEGRAM_WEBHOOK_SECRET

# =========================
# Polygon Anchoring (weekly batch job)
# =========================
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_CHAIN_ID=137
ANCHOR_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
ANCHOR_SIGNER_PRIVATE_KEY=YOUR_PRIVATE_KEY
POLYGONSCAN_BASE_URL=https://polygonscan.com/tx/

# =========================
# Cron / Batch Config
# =========================
ANCHOR_BATCH_CRON=0 1 * * 1
ANCHOR_BATCH_SIZE=5000

# =========================
# Public Verify App (Next.js)
# =========================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_VERIFY_BASE_URL=http://localhost:3000/verify

# =========================
# Billing / Trial
# =========================
DEFAULT_TRIAL_DAYS=14
KHQR_SUPPORT_CONTACT=+855XXXXXXXX

# =========================
# Observability
# =========================
LOG_LEVEL=info
SENTRY_DSN=
HEALTHCHECK_SHARED_TOKEN=replace-with-long-random-string
