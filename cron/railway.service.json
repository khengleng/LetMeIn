{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm ci",
    "watchPatterns": [
      "cron/**",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "node index.js",
    "healthcheckPath": "/ping",
    "healthcheckTimeout": 90,
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 0
  }
}
