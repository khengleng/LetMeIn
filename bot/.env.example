NODE_ENV=development
PORT=3001

TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=YOUR_TELEGRAM_BOT_USERNAME

# Public URL for webhook mode (Vercel/Render). No trailing slash.
WEBHOOK_BASE_URL=https://your-bot-domain.com
WEBHOOK_SECRET_PATH=replace-with-random-path-token
WEBHOOK_SECRET_TOKEN=replace-with-random-header-token

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Edge Function endpoint (write path only)
SUPABASE_LOG_REFERRAL_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/log-referral

# JWT forwarded to log-referral for tenant-aware RLS write checks
BOT_SUPABASE_JWT=tenant-scoped-jwt

# Fallback tenant for /mylink when tenant context is not yet user-bound
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000

# Optional defaults and operational safety
DEFAULT_REFERRAL_STATUS=pending
REQUEST_TIMEOUT_MS=8000
